// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Empleado / vinculado ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model NomEmpleado {
  id              String   @id @default(cuid())
  documento       String   @unique
  tipoDocumento   String                                       // CC|CE|PA|NIT
  primerNombre    String
  segundoNombre   String?
  primerApellido  String
  segundoApellido String?
  email           String?
  telefono        String?
  cargo           String
  dependencia     String?
  tipoVinculacion NomTipoVinculacion @default(PLANTA)
  fechaIngreso    DateTime
  fechaRetiro     DateTime?
  activo          Boolean  @default(true)
  salarioBasico   Decimal  @db.Decimal(18, 2)
  // Identificadores bancarios / aportes
  cuentaBanco     String?
  bancoNombre     String?
  tipoCuenta      String?                                      // AHORROS|CORRIENTE
  eps             String?
  afp             String?
  arl             String?
  cajaCompensacion String?
  // InformaciГғВіn tributaria
  retencionFuenteAplica Boolean @default(true)

  liquidaciones NomLiquidacion[]
  novedades     NomNovedad[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activo])
  @@index([dependencia])
  @@map("nom_empleados")
}

enum NomTipoVinculacion {
  PLANTA            // empleado pГғВәblico de carrera o libre nombramiento
  TRABAJADOR_OFICIAL
  CONTRATISTA       // OPS ГўвӮ¬вҖқ prestaciГғВіn de servicios
  SUPERNUMERARIO
  APRENDIZ
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Concepto de nГғВіmina (devengado o deducciГғВіn) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model NomConcepto {
  id          String   @id @default(cuid())
  codigo      String   @unique                                // NC-001, NC-002
  nombre      String
  tipo        NomTipoConcepto
  // Base de cГғВЎlculo
  formula     NomFormulaConcepto @default(FIJO)
  porcentaje  Decimal? @db.Decimal(6, 4)                      // ej 0.04 = 4%
  valorFijo   Decimal? @db.Decimal(18, 2)
  // Aplica a
  aplicaA     NomTipoVinculacion[]                            // a quiГғВ©nes aplica
  // Comportamiento contable / tributario
  baseRetencion Boolean @default(false)                       // suma a base retenciГғВіn
  baseAportes   Boolean @default(false)                       // suma a IBC
  constitutivoSalario Boolean @default(true)
  // Cuenta CGC asociada (gasto si devengado, pasivo si deducciГғВіn)
  cuentaContableCodigo String?                                // ej "510101", "243603"
  // Rubro CCPET asociado (sГғВіlo devengados)
  rubroCcpetCodigo     String?                                // ej "2.1.1.01.01.01.01"
  // Orden de aplicaciГғВіn dentro de la liquidaciГғВіn
  orden       Int      @default(100)
  activo      Boolean  @default(true)

  detalles    NomLiquidacionDetalle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nom_conceptos")
}

enum NomTipoConcepto {
  DEVENGADO            // sueldo, prima, bonificaciГғВіn, auxilio
  DEDUCCION_EMPLEADO   // pensiГғВіn 4%, salud 4%, retefuente, embargos
  APORTE_PATRONAL      // pensiГғВіn 12%, salud 8.5%, ARL, parafiscales
  PRESTACION_SOCIAL    // cesantГғВӯas, intereses, primas (provisiones)
}

enum NomFormulaConcepto {
  FIJO                 // valorFijo en el empleado (manual)
  PORCENTAJE_SUELDO    // porcentaje * salarioBasico
  PORCENTAJE_DEVENGADO // porcentaje * suma devengados constitutivos
  PORCENTAJE_IBC       // porcentaje * Ingreso Base de CotizaciГғВіn
  CALCULO_ESPECIAL     // ej cesantГғВӯas: prom 12 meses, vacaciones: dГғВӯas*salario/30
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Periodo de nГғВіmina ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model NomNominaPeriodo {
  id          String   @id @default(cuid())
  codigo      String   @unique                                // "2026-05"
  anio        Int
  mes         Int                                             // 1..12
  estado      NomEstadoPeriodo @default(ABIERTO)
  fechaInicio DateTime
  fechaFin    DateTime
  liquidadoEn DateTime?
  liquidadoPor String?

  liquidaciones NomLiquidacion[]
  pagosPasivos  NomPagoPasivo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([anio, mes])
  @@map("nom_periodos")
}

enum NomEstadoPeriodo {
  ABIERTO          // se puede liquidar
  LIQUIDADO        // ya liquidado, sГғВіlo lectura
  PAGADO           // pagado a empleados (genera comprobantes)
  CERRADO          // cerrado contablemente
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ LiquidaciГғВіn (1 por empleado por periodo) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model NomLiquidacion {
  id          String   @id @default(cuid())
  periodoId   String
  periodo     NomNominaPeriodo @relation(fields: [periodoId], references: [id])
  empleadoId  String
  empleado    NomEmpleado @relation(fields: [empleadoId], references: [id])
  // Acumulados
  totalDevengado Decimal @db.Decimal(18, 2) @default(0)
  totalDeducciones Decimal @db.Decimal(18, 2) @default(0)
  totalAportesPatronales Decimal @db.Decimal(18, 2) @default(0)
  netoPagar      Decimal @db.Decimal(18, 2) @default(0)
  // DГғВӯas liquidados
  diasLiquidados Int @default(30)
  // Salario base usado
  salarioBasico  Decimal @db.Decimal(18, 2)
  // VГғВӯnculos a presupuesto / contabilidad
  obligacionId   String?
  comprobanteId  String?

  detalles NomLiquidacionDetalle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodoId, empleadoId])
  @@index([empleadoId])
  @@map("nom_liquidaciones")
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Detalle de liquidaciГғВіn (lГғВӯnea por concepto aplicado) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model NomLiquidacionDetalle {
  id            String   @id @default(cuid())
  liquidacionId String
  liquidacion   NomLiquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  conceptoId    String
  concepto      NomConcepto @relation(fields: [conceptoId], references: [id])
  valor         Decimal  @db.Decimal(18, 2)
  base          Decimal? @db.Decimal(18, 2)                   // base usada para el cГғВЎlculo
  observacion   String?

  createdAt DateTime @default(now())

  @@index([liquidacionId])
  @@index([conceptoId])
  @@map("nom_liquidacion_detalles")
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Novedad (vacaciones, licencia, ausencia, incapacidad) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model NomNovedad {
  id          String   @id @default(cuid())
  empleadoId  String
  empleado    NomEmpleado @relation(fields: [empleadoId], references: [id])
  tipo        NomTipoNovedad
  fechaInicio DateTime
  fechaFin    DateTime
  dias        Int
  observacion String?
  valor       Decimal? @db.Decimal(18, 2)                     // si aplica (ej. liquidaciГғВіn de vacaciones)
  aprobada    Boolean @default(false)
  aprobadaPor String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empleadoId])
  @@index([fechaInicio])
  @@map("nom_novedades")
}

enum NomTipoNovedad {
  VACACIONES
  LICENCIA_REMUNERADA
  LICENCIA_NO_REMUNERADA
  INCAPACIDAD_EPS          // pagada por EPS
  INCAPACIDAD_ARL          // pagada por ARL
  AUSENCIA                 // descontable
  COMISION_SERVICIOS
  PERMISO
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Pago de pasivos de nГғВіmina (EPS/AFP/DIAN/parafiscales) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model NomPagoPasivo {
  id              String   @id @default(cuid())
  periodoId       String
  periodo         NomNominaPeriodo @relation(fields: [periodoId], references: [id])
  cuentaCodigo    String                                         // 2505, 2510, 2425, 2436...
  cuentaNombre    String                                         // copia para historial sin join
  tercero         String                                         // "EPS Sanitas", "DIAN", "Colpensiones"...
  terceroNit      String?
  valor           Decimal  @db.Decimal(18, 2)
  fecha           DateTime
  cuentaBancoCodigo String                                       // banco que pagГғВі
  comprobanteId   String?                                        // CpComprobante creado
  observacion     String?
  creadoPor       String?

  createdAt DateTime @default(now())

  @@index([periodoId])
  @@index([cuentaCodigo])
  @@map("nom_pagos_pasivos")
}

// ГўвҖўвҖқГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўвҖ”
// ГўвҖўвҖҳ MГғвҖңDULO: Reportes a entes de control (reportes_control)                     ГўвҖўвҖҳ
// ГўвҖўвҖҳ Genera snapshots periГғВіdicos para CHIP (CGN), FUT (DNP), Ley 617,           ГўвҖўвҖҳ
// ГўвҖўвҖҳ persistidos como JSON descargable para mapear a las plantillas oficiales.  ГўвҖўвҖҳ
// ГўвҖўЕЎГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВқ

model RcReporteGenerado {
  id           String   @id @default(cuid())
  tipo         RcTipoReporte
  // IdentificaciГғВіn del corte (uno de los dos segГғВәn el tipo):
  periodoContableId String?                                  // CHIP_BALANCE / CHIP_ACTIVIDAD
  vigencia          Int?                                     // FUT_INGRESOS / FUT_GASTOS / LEY_617
  // Resultado
  datos        Json
  totales      Json?                                         // resumen para listar
  // Metadata
  generadoPor  String?
  generadoEn   DateTime @default(now())
  observacion  String?

  @@index([tipo, vigencia])
  @@index([tipo, periodoContableId])
  @@map("rc_reportes")
}

enum RcTipoReporte {
  CHIP_BALANCE       // Balance General CGN: saldos clase 1, 2, 3 al cierre del periodo
  CHIP_ACTIVIDAD     // Estado de Actividad CGN: ingresos (clase 4) y gastos (clase 5)
  FUT_INGRESOS       // EjecuciГғВіn de ingresos por rubro CCPET
  FUT_GASTOS         // EjecuciГғВіn de gastos: apropiaciГғВіn / comprometido / obligado / pagado
  LEY_617            // Indicador gastos de funcionamiento sobre ICLD (40% para personerГғВӯas)
}


// в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// в•‘ MГ“DULO: TesorerГӯa (tesoreria)                                               в•‘
// в•‘ GestiГіn de cuentas bancarias institucionales, movimientos y conciliaciГіn    в•‘
// в•‘ con extractos. Integra con CpComprobante (contabilidad) y PsuPago           в•‘
// в•‘ (presupuesto) para cruzar libros.                                           в•‘
// в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

// в”Җв”Җв”Җ Cuenta bancaria de la entidad в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model TesoCuenta {
  id             String   @id @default(cuid())
  nombre         String                                         // "Cuenta corriente Banco Popular"
  banco          String                                         // "Banco Popular"
  nitBanco       String?
  numeroCuenta   String                                         // nГәmero de cuenta (sin espacios)
  tipo           TesoCuentaTipo @default(CORRIENTE)
  moneda         String  @default("COP")
  activa         Boolean @default(true)
  descripcion    String?
  // Cuenta contable CGC asociada (111*) вҖ“ opcional si contabilidad estГЎ activa
  cuentaContableCodigo String?

  movimientos    TesoMovimiento[]
  extractos      TesoExtracto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activa])
  @@map("teso_cuentas")
}

enum TesoCuentaTipo {
  CORRIENTE
  AHORROS
  INVERSION_TEMPORAL    // CDT / tГӯtulos de tesorerГӯa
  FONDOS_ESPECIALES     // SGP, regalГӯas, fideicomisos
}

// в”Җв”Җв”Җ Movimiento (lГӯnea del libro de tesorerГӯa) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model TesoMovimiento {
  id             String   @id @default(cuid())
  cuentaId       String
  cuenta         TesoCuenta @relation(fields: [cuentaId], references: [id])
  tipo           TesoTipoMovimiento
  fecha          DateTime
  valor          Decimal  @db.Decimal(18, 2)
  descripcion    String
  numero         String?                                        // nГәmero interno (OR, OE, rec, etc.)
  tercero        String?
  terceroNit     String?
  // Cruce con otros mГіdulos
  comprobanteId  String?                                        // вҶ’ CpComprobante
  pagoPresupId   String?                                        // вҶ’ PsuPago
  // ConciliaciГіn
  conciliado     Boolean @default(false)
  conciliadoEn   DateTime?
  extractoLineaId String?                                       // вҶ’ TesoExtractoLinea
  creadoPor      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cuentaId, fecha])
  @@index([conciliado])
  @@index([comprobanteId])
  @@map("teso_movimientos")
}

enum TesoTipoMovimiento {
  INGRESO       // crГ©dito en banco
  EGRESO        // dГ©bito en banco
}

// в”Җв”Җв”Җ Extracto bancario (carga periГіdica para conciliar) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model TesoExtracto {
  id          String   @id @default(cuid())
  cuentaId    String
  cuenta      TesoCuenta @relation(fields: [cuentaId], references: [id])
  periodo     String                                           // "2025-04" (YYYY-MM)
  saldoInicial Decimal @db.Decimal(18, 2)
  saldoFinal   Decimal @db.Decimal(18, 2)
  cargadoPor   String?
  observacion  String?

  lineas      TesoExtractoLinea[]

  createdAt DateTime @default(now())

  @@unique([cuentaId, periodo])
  @@index([cuentaId])
  @@map("teso_extractos")
}

model TesoExtractoLinea {
  id          String   @id @default(cuid())
  extractoId  String
  extracto    TesoExtracto @relation(fields: [extractoId], references: [id], onDelete: Cascade)
  fecha       DateTime
  descripcion String
  referencia  String?
  debito      Decimal? @db.Decimal(18, 2)
  credito     Decimal? @db.Decimal(18, 2)
  saldo       Decimal? @db.Decimal(18, 2)
  // ConciliaciГіn
  conciliada     Boolean @default(false)
  movimientoId   String?                                      // вҶ’ TesoMovimiento.id (cuando concilia)

  @@index([extractoId])
  @@index([conciliada])
  @@map("teso_extracto_lineas")
}


// в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// в•‘ MГ“DULO: ContrataciГіn pГәblica (contratacion)                                 в•‘
// в•‘ Procesos contractuales Ley 80/1150: licitaciГіn, selecciГіn abreviada,        в•‘
// в•‘ mГӯnima cuantГӯa, contrataciГіn directa. Ciclo: precontractual вҶ’ contrato      в•‘
// в•‘ вҶ’ liquidaciГіn. Integra con CDP/RP del mГіdulo presupuesto.                  в•‘
// в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

model ConProceso {
  id               String   @id @default(cuid())
  numero           String   @unique
  modalidad        ConModalidad
  estado           ConEstadoProceso @default(PLANEACION)
  objeto           String
  vigencia         Int
  valorEstimado    Decimal  @db.Decimal(18, 2)
  cdpId            String?
  cdpNumero        String?
  rubroNombre      String?
  fechaAviso       DateTime?
  fechaCierre      DateTime?
  fechaAdjudicacion DateTime?
  supervisorNombre String?
  supervisorCargo  String?
  dependencia      String?
  creadoPor        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  contratos        ConContrato[]
  documentos       ConDocumento[]

  @@index([estado])
  @@index([vigencia])
  @@index([modalidad])
  @@map("con_procesos")
}

enum ConModalidad {
  LICITACION_PUBLICA
  SELECCION_ABREVIADA
  CONCURSO_MERITOS
  CONTRATACION_DIRECTA
  MINIMA_CUANTIA
  ASOCIACION_PUBLICO_PRIVADA
}

enum ConEstadoProceso {
  PLANEACION
  CONVOCATORIA
  EVALUACION
  ADJUDICADO
  CONTRATADO
  LIQUIDADO
  DESIERTO
  REVOCADO
}

model ConContrato {
  id                   String   @id @default(cuid())
  procesoId            String
  proceso              ConProceso @relation(fields: [procesoId], references: [id])
  numero               String   @unique
  tipo                 ConTipoContrato
  estado               ConEstadoContrato @default(SUSCRITO)
  contratistaNombre    String
  contratistaDoc       String
  contratistaEmail     String?
  contratistaTelefono  String?
  valorContrato        Decimal  @db.Decimal(18, 2)
  valorAdiciones       Decimal  @db.Decimal(18, 2) @default(0)
  plazoMeses           Int?
  fechaSuscripcion     DateTime
  fechaInicio          DateTime?
  fechaTerminacion     DateTime?
  fechaLiquidacion     DateTime?
  rpId                 String?
  rpNumero             String?
  supervisorNombre     String?
  observacion          String?
  creadoPor            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  documentos           ConDocumento[]
  adiciones            ConAdicion[]

  @@index([procesoId])
  @@index([estado])
  @@index([fechaTerminacion])
  @@map("con_contratos")
}

enum ConTipoContrato {
  PRESTACION_SERVICIOS
  COMPRAVENTA
  SUMINISTRO
  OBRA_PUBLICA
  CONSULTORIA
  INTERADMINISTRATIVO
  CONCESION
  ARRENDAMIENTO
  COMODATO
  CONVENIO
  OTRO
}

enum ConEstadoContrato {
  SUSCRITO
  EN_EJECUCION
  SUSPENDIDO
  TERMINADO
  LIQUIDADO
  INCUMPLIDO
}

model ConAdicion {
  id            String   @id @default(cuid())
  contratoId    String
  contrato      ConContrato @relation(fields: [contratoId], references: [id])
  tipo          ConTipoAdicion
  numero        String
  valor         Decimal? @db.Decimal(18, 2)
  plazoMeses    Int?
  fecha         DateTime
  justificacion String
  createdAt     DateTime @default(now())

  @@index([contratoId])
  @@map("con_adiciones")
}

enum ConTipoAdicion {
  ADICION_VALOR
  PROROGA
  ADICION_VALOR_Y_PROROGA
  SUSPENSION
  REINICIO
}

model ConDocumento {
  id          String   @id @default(cuid())
  procesoId   String?
  proceso     ConProceso? @relation(fields: [procesoId], references: [id])
  contratoId  String?
  contrato    ConContrato? @relation(fields: [contratoId], references: [id])
  tipo        ConTipoDocumento
  nombre      String
  url         String?
  fechaDoc    DateTime?
  observacion String?
  creadoPor   String?
  createdAt   DateTime @default(now())

  @@index([procesoId])
  @@index([contratoId])
  @@map("con_documentos")
}

enum ConTipoDocumento {
  ESTUDIO_PREVIO
  AVISO_CONVOCATORIA
  PLIEGO_CONDICIONES
  ADENDA
  PROPUESTA_OFERENTE
  INFORME_EVALUACION
  ACTO_ADJUDICACION
  CONTRATO
  POLIZA
  ACTA_INICIO
  INFORME_SUPERVISION
  ACTA_SUSPENSION
  ACTA_REINICIO
  ACTA_TERMINACION
  ACTA_LIQUIDACION
  OTRO
}

// ============================================================================
// ACTIVOS BIENES вҖ” Inventario institucional de bienes muebles e inmuebles
// ----------------------------------------------------------------------------
// Activado por el mГіdulo ctivos_bienes. Cubre el ciclo completo:
// ingreso вҶ’ asignaciГіn вҶ’ mantenimiento вҶ’ traslado вҶ’ baja.
// ============================================================================

model ActivoBien {
  id              String           @id @default(cuid())
  codigo          String           @unique        // placa o cГіdigo institucional
  nombre          String
  descripcion     String?
  categoria       ActivoCategoria
  tipo            String?                         // ej: "Laptop", "Escritorio"
  marca           String?
  modelo          String?
  serial          String?
  color           String?
  // ValoraciГіn
  valorAdquisicion Decimal?        @db.Decimal(18, 2)
  fechaAdquisicion DateTime?
  vidaUtilAnios   Int?
  // UbicaciГіn y responsable
  dependenciaId   String?          // GdTrdDependencia.id si GD activo
  dependenciaNombre String?        // nombre libre cuando GD no activo
  responsableId   String?          // User.id
  responsableNombre String?
  ubicacion       String?          // descripciГіn libre de ubicaciГіn fГӯsica
  // Estado del bien
  estado          ActivoEstado     @default(EN_SERVICIO)
  // Imagen
  imagenUrl       String?
  // Observaciones
  observaciones   String?
  creadoPor       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  asignaciones    ActivoAsignacion[]
  mantenimientos  ActivoMantenimiento[]
  movimientos     ActivoMovimiento[]

  @@index([codigo])
  @@index([estado])
  @@index([categoria])
  @@map("activos_bienes")
}

model ActivoAsignacion {
  id          String   @id @default(cuid())
  activoId    String
  activo      ActivoBien @relation(fields: [activoId], references: [id], onDelete: Cascade)
  // A quiГ©n se asigna
  funcionarioId   String?
  funcionarioNombre String
  dependenciaNombre String?
  // Fechas
  fechaInicio DateTime
  fechaFin    DateTime?
  // Acta
  actaNumero  String?
  observacion String?
  creadoPor   String?
  createdAt   DateTime @default(now())

  @@index([activoId])
  @@index([fechaInicio])
  @@map("activos_asignaciones")
}

model ActivoMantenimiento {
  id          String   @id @default(cuid())
  activoId    String
  activo      ActivoBien @relation(fields: [activoId], references: [id], onDelete: Cascade)
  tipo        ActivoTipoMantenimiento
  fecha       DateTime
  descripcion String
  proveedor   String?
  costo       Decimal? @db.Decimal(18, 2)
  proximoMantenimiento DateTime?
  creadoPor   String?
  createdAt   DateTime @default(now())

  @@index([activoId])
  @@map("activos_mantenimientos")
}

model ActivoMovimiento {
  id          String   @id @default(cuid())
  activoId    String
  activo      ActivoBien @relation(fields: [activoId], references: [id], onDelete: Cascade)
  tipo        ActivoTipoMovimiento
  fecha       DateTime
  descripcion String
  // Origen/destino para traslados
  origenDependencia  String?
  destinoDependencia String?
  actaNumero  String?
  creadoPor   String?
  createdAt   DateTime @default(now())

  @@index([activoId])
  @@map("activos_movimientos")
}

enum ActivoCategoria {
  MUEBLE_ENSERE       // escritorios, sillas, archivadores
  EQUIPO_COMPUTO      // laptops, desktops, impresoras
  EQUIPO_COMUNICACION // telГ©fonos, radios, redes
  EQUIPO_AUDIOVISUAL  // proyectores, televisores
  MAQUINARIA_EQUIPO   // maquinaria especializada
  VEHICULO            // carros, motos, bicicletas
  INMUEBLE            // edificios, lotes propios
  SEMOVIENTE          // animales (alcaldГӯas rurales)
  INTANGIBLE          // licencias, software perpetuo
  OTRO
}

enum ActivoEstado {
  EN_SERVICIO
  EN_MANTENIMIENTO
  EN_BODEGA
  DADO_DE_BAJA
  EXTRAVIADO
}

enum ActivoTipoMantenimiento {
  PREVENTIVO
  CORRECTIVO
  GARANTIA
}

enum ActivoTipoMovimiento {
  INGRESO          // entrada por primera vez
  ASIGNACION       // entrega a funcionario
  TRASLADO         // cambio de dependencia
  DEVOLUCION       // retorno a bodega
  BAJA             // retiro definitivo
  REINTEGRO        // recuperaciГіn de perdido
}

// ============================================================================
// ALMACГүN вҖ” GestiГіn de inventario de suministros y elementos de consumo
// ----------------------------------------------------------------------------
// Activado por el mГіdulo lmacen. Cubre: artГӯculos вҶ’ entradas вҶ’ salidas.
// El stock actual se calcula como ОЈ entradas - ОЈ salidas en la aplicaciГіn.
// ============================================================================

model AlmArticulo {
  id              String   @id @default(cuid())
  codigo          String   @unique
  nombre          String
  descripcion     String?
  unidad          String                     // ej: "Unidad", "Resma", "Litro"
  categoria       AlmCategoria
  marca           String?
  stockMinimo     Int      @default(0)
  stockActual     Int      @default(0)       // desnormalizado, actualizado en cada E/S
  ubicacionBodega String?                    // estante/posiciГіn en bodega
  activo          Boolean  @default(true)
  imagenUrl       String?
  creadoPor       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  entradas AlmEntrada[]
  salidas  AlmSalida[]

  @@index([codigo])
  @@index([categoria])
  @@index([activo])
  @@map("alm_articulos")
}

model AlmEntrada {
  id           String   @id @default(cuid())
  articuloId   String
  articulo     AlmArticulo @relation(fields: [articuloId], references: [id])
  tipo         AlmTipoEntrada
  cantidad     Int
  valorUnitario Decimal? @db.Decimal(18, 2)
  fechaEntrada DateTime
  // Referencia documental
  ordenCompraNumero String?
  facturaNumero     String?
  proveedor         String?
  observacion       String?
  creadoPor         String?
  createdAt         DateTime @default(now())

  @@index([articuloId])
  @@index([fechaEntrada])
  @@map("alm_entradas")
}

model AlmSalida {
  id           String   @id @default(cuid())
  articuloId   String
  articulo     AlmArticulo @relation(fields: [articuloId], references: [id])
  cantidad     Int
  fechaSalida  DateTime
  // Destino
  dependenciaNombre String?
  funcionarioNombre String?
  // Referencia documental
  actaNumero   String?
  observacion  String?
  creadoPor    String?
  createdAt    DateTime @default(now())

  @@index([articuloId])
  @@index([fechaSalida])
  @@map("alm_salidas")
}

enum AlmCategoria {
  PAPELERIA_UTILES     // papel, esferos, carpetas
  ASEO_CAFETERIA       // jabГіn, escobas, cafГ©
  TONER_INSUMOS_TIC    // tГіner, cables, mouse
  HERRAMIENTAS         // destornilladores, llaves
  MEDICAMENTOS         // botiquГӯn
  COMBUSTIBLE          // gasolina, ACPM
  MATERIALES_OBRA      // cemento, pintura
  OTRO
}

enum AlmTipoEntrada {
  COMPRA
  DONACION
  REINTEGRO            // devoluciГіn de una salida
  AJUSTE_POSITIVO      // correcciГіn de inventario
}

// ============================================================================
// OBSERVATORIO вҖ” Indicadores de gestiГіn y tablero pГәblico
// ----------------------------------------------------------------------------
// Activado por el mГіdulo observatorio. Permite publicar indicadores de
// desempeГұo institucional con seguimiento histГіrico de mediciones.
// ============================================================================

model ObsIndicador {
  id                String             @id @default(cuid())
  codigo            String             @unique
  nombre            String
  descripcion       String?
  unidad            String                         // ej: "%", "Casos", "DГӯas"
  categoria         ObsCategoria
  periodicidad      ObsPeriodicidad
  meta              Decimal            @db.Decimal(18, 4)
  metaTipo          ObsMetaTipo        @default(MAYOR_ES_MEJOR)
  dependenciaNombre String?
  responsableNombre String?
  // PublicaciГіn
  publicado         Boolean            @default(true)
  orden             Int                @default(0)
  // Valor mГЎs reciente (desnormalizado para lectura rГЎpida)
  valorActual       Decimal?           @db.Decimal(18, 4)
  fechaUltimaMedicion DateTime?
  creadoPor         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  mediciones ObsMedicion[]

  @@index([categoria])
  @@index([publicado])
  @@map("obs_indicadores")
}

model ObsMedicion {
  id           String       @id @default(cuid())
  indicadorId  String
  indicador    ObsIndicador @relation(fields: [indicadorId], references: [id], onDelete: Cascade)
  valor        Decimal      @db.Decimal(18, 4)
  fecha        DateTime
  periodo      String                             // ej: "2025-T1", "2025-03", "2025"
  fuente       String?
  observacion  String?
  creadoPor    String?
  createdAt    DateTime     @default(now())

  @@index([indicadorId])
  @@index([fecha])
  @@map("obs_mediciones")
}

enum ObsCategoria {
  GESTION_INTERNA       // eficiencia administrativa
  ATENCION_CIUDADANA    // tiempos de respuesta PQRSD
  FINANCIERO            // ejecuciГіn presupuestal
  CONTRATACION          // contratos suscritos vs plan
  GESTION_DOCUMENTAL    // radicados atendidos
  TALENTO_HUMANO        // capacitaciones, ausentismo
  MIPG                  // cumplimiento MIPG/FURAG
  OTRO
}

enum ObsPeriodicidad {
  DIARIA
  SEMANAL
  MENSUAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

enum ObsMetaTipo {
  MAYOR_ES_MEJOR    // ej: % ejecuciГіn presupuestal вҖ” quiero llegar a 100%
  MENOR_ES_MEJOR    // ej: dГӯas promedio de respuesta вҖ” quiero bajar
  EXACTO            // ej: temperatura objetivo
}

// ============================================================================
// RENTAS LOCALES вҖ” GestiГіn tributaria municipal (predial, ICA, estampillasвҖҰ)
// ----------------------------------------------------------------------------
// Activado por el mГіdulo entas_locales. Ciclo: concepto вҶ’ contribuyente
// вҶ’ liquidaciГіn вҶ’ pago. Soporta recaudo propio y acuerdos de pago.
// ============================================================================

model RenConcepto {
  id           String          @id @default(cuid())
  codigo       String          @unique
  nombre       String
  descripcion  String?
  tipo         RenTipoConcepto
  periodicidad RenPeriodicidad
  tasaBase     Decimal?        @db.Decimal(10, 6)  // porcentaje o tarifa base
  activo       Boolean         @default(true)
  creadoPor    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  liquidaciones RenLiquidacion[]

  @@index([tipo])
  @@map("ren_conceptos")
}

model RenContribuyente {
  id           String   @id @default(cuid())
  documento    String   @unique
  tipoDoc      String   @default("NIT")   // CC, NIT, CE, PASAPORTE
  nombre       String
  razonSocial  String?
  direccion    String?
  telefono     String?
  email        String?
  activo       Boolean  @default(true)
  creadoPor    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  liquidaciones RenLiquidacion[]

  @@index([documento])
  @@map("ren_contribuyentes")
}

model RenLiquidacion {
  id               String              @id @default(cuid())
  numero           String              @unique
  conceptoId       String
  concepto         RenConcepto         @relation(fields: [conceptoId], references: [id])
  contribuyenteId  String
  contribuyente    RenContribuyente    @relation(fields: [contribuyenteId], references: [id])
  vigencia         Int                                       // aГұo fiscal
  periodo          String?                                   // "T1", "03", etc.
  baseGravable     Decimal             @db.Decimal(18, 2)
  tarifa           Decimal             @db.Decimal(10, 6)
  impuesto         Decimal             @db.Decimal(18, 2)
  intereses        Decimal             @default(0) @db.Decimal(18, 2)
  descuentos       Decimal             @default(0) @db.Decimal(18, 2)
  totalACobrar     Decimal             @db.Decimal(18, 2)
  totalPagado      Decimal             @default(0) @db.Decimal(18, 2)
  saldo            Decimal             @db.Decimal(18, 2)
  estado           RenEstadoLiquidacion @default(PENDIENTE)
  fechaVencimiento DateTime?
  observacion      String?
  creadoPor        String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  pagos RenPago[]

  @@index([contribuyenteId])
  @@index([conceptoId])
  @@index([vigencia])
  @@index([estado])
  @@map("ren_liquidaciones")
}

model RenPago {
  id              String   @id @default(cuid())
  liquidacionId   String
  liquidacion     RenLiquidacion @relation(fields: [liquidacionId], references: [id])
  valor           Decimal  @db.Decimal(18, 2)
  fecha           DateTime
  medioPago       RenMedioPago
  referencia      String?         // nГәmero de recibo, transacciГіn bancaria
  observacion     String?
  creadoPor       String?
  createdAt       DateTime @default(now())

  @@index([liquidacionId])
  @@index([fecha])
  @@map("ren_pagos")
}

enum RenTipoConcepto {
  PREDIAL_UNIFICADO
  INDUSTRIA_COMERCIO
  SOBRETASA_GASOLINA
  ESTAMPILLA
  DELINEACION_URBANA
  AVISOS_TABLEROS
  PLUSVALIA
  ALUMBRADO_PUBLICO
  OTRO
}

enum RenPeriodicidad {
  ANUAL
  SEMESTRAL
  TRIMESTRAL
  MENSUAL
  UNICA
}

enum RenEstadoLiquidacion {
  PENDIENTE
  PARCIAL
  PAGADA
  VENCIDA
  EN_ACUERDO_PAGO
  ANULADA
}

enum RenMedioPago {
  EFECTIVO
  TRANSFERENCIA
  PSE
  CHEQUE
  DATAFONO
  OTRO
}