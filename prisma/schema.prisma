  token  String @unique  // se entrega al ciudadano
  pqrsId String
  pqrs   PQRS   @relation(fields: [pqrsId], references: [id], onDelete: Cascade)

  // Permisos del token
  permiteConsulta  Boolean @default(true)
  permiteResponder Boolean @default(false)

  expiraEn   DateTime?
  ultimoUsoEn DateTime?
  vecesUsado  Int      @default(0)
  revocadoEn  DateTime?

  createdAt DateTime @default(now())

  @@index([pqrsId])
  @@map("vu_rutas_token_externo")
}

// ============================================================================
// FRISCO — Bienes en proceso de extinción de dominio (módulo vertical SAE)
// ----------------------------------------------------------------------------
// Activado por el módulo `frisco_bienes`. Cada bien queda vinculado a un
// expediente documental (GdExpediente) y, opcionalmente, a su ubicación
// física en archivo (GaCarpeta) cuando aplica. Tablas pensadas para soportar
// el ciclo: ingreso por orden judicial → custodia → contratos → destinación.
// ============================================================================

model FriscoBien {
  id              String   @id @default(cuid())
  codigo          String   @unique                 // consecutivo interno
  folioMatricula  String?                          // SNR — inmuebles
  placa           String?                          // automotores
  tipo            FriscoTipoBien
  estadoJuridico  FriscoEstadoJuridico @default(EN_PROCESO)
  estadoFisico    FriscoEstadoFisico?  @default(SIN_VERIFICAR)

  descripcion     String   @db.Text
  ubicacion       String?                          // dirección textual
  latitud         Float?
  longitud        Float?

  avaluoVigente   Decimal? @db.Decimal(18, 2)
  monedaAvaluo    String?  @default("COP")
  fechaAvaluo     DateTime?

  numeroProceso   String?                          // proceso de extinción
  fechaIngreso    DateTime @default(now())
  juzgado         String?

  // Vínculos a documentación
  expedienteId    String?
  expediente      GdExpediente? @relation(fields: [expedienteId], references: [id])
  carpetaFisicaId String?
  carpetaFisica   GaCarpeta?    @relation(fields: [carpetaFisicaId], references: [id])

  depositarios FriscoDepositario[]
  contratos    FriscoContrato[]
  destinacion  FriscoDestinacion?
  interopLogs  FriscoInteropLog[]

  observaciones String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estadoJuridico])
  @@index([tipo])
  @@index([folioMatricula])
  @@index([placa])
  @@index([numeroProceso])
  @@map("frisco_bienes")
}

enum FriscoTipoBien {
  INMUEBLE_URBANO
  INMUEBLE_RURAL
  VEHICULO
  SEMOVIENTE
  ESTABLECIMIENTO_COMERCIO
  EMBARCACION
  AERONAVE
  OBRA_ARTE
  TITULO_VALOR
  EMPRESA
  OTRO
}

enum FriscoEstadoJuridico {
  EN_PROCESO   // proceso activo de extinción
  CAUTELAR     // medida cautelar vigente
  EXTINTO      // sentencia de extinción ejecutoriada
  DEVUELTO     // devuelto al propietario original
}

enum FriscoEstadoFisico {
  BUENO
  REGULAR
  MALO
  PERDIDO
  DESTRUIDO
  SIN_VERIFICAR
}

// ─── Depositario: custodio temporal de un bien ────────────────────────────────

model FriscoDepositario {
  id          String   @id @default(cuid())
  tipoPersona FriscoTipoPersona
  nombre      String
  documento   String                              // cédula o NIT
  email       String?
  telefono    String?
  direccion   String?

  bienId String
  bien   FriscoBien @relation(fields: [bienId], references: [id], onDelete: Cascade)

  fechaAsignacion    DateTime
  fechaFin           DateTime?
  activo             Boolean   @default(true)
  ultimoReporte      DateTime?
  polizaVigenteHasta DateTime?

  observaciones String? @db.Text

  accesos  FriscoPortalAcceso[]
  reportes FriscoReporteDepositario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bienId])
  @@index([activo])
  @@index([documento])
  @@map("frisco_depositarios")
}

enum FriscoTipoPersona {
  NATURAL
  JURIDICA
}

// ─── Portal externo del depositario: acceso por token + reportes mensuales ───

model FriscoPortalAcceso {
  id            String   @id @default(cuid())
  tokenHash     String   @unique                    // SHA-256 del token; el token plano nunca se persiste
  depositarioId String
  depositario   FriscoDepositario @relation(fields: [depositarioId], references: [id], onDelete: Cascade)

  expiraEn      DateTime
  revocadoEn    DateTime?
  ultimoAccesoEn DateTime?
  accesoCount   Int      @default(0)

  createdAt DateTime @default(now())
  createdBy String?

  @@index([depositarioId])
  @@index([expiraEn])
  @@map("frisco_portal_accesos")
}

model FriscoReporteDepositario {
  id            String   @id @default(cuid())
  depositarioId String
  depositario   FriscoDepositario @relation(fields: [depositarioId], references: [id], onDelete: Cascade)

  periodo       String                              // "YYYY-MM"
  estadoBien    FriscoEstadoFisico
  novedades     String   @db.Text
  fotoUrl       String?                             // URL de foto subida (opcional)
  adjuntoUrl    String?                             // URL de documento adjunto (opcional)
  ipOrigen      String?

  analisisIA    FriscoReporteAnalisisIA?

  createdAt DateTime @default(now())

  @@unique([depositarioId, periodo])
  @@index([periodo])
  @@map("frisco_reportes_depositario")
}

// ─── Análisis IA del reporte (sugiere, humano decide) ────────────────────────

model FriscoReporteAnalisisIA {
  id          String   @id @default(cuid())
  reporteId   String   @unique
  reporte     FriscoReporteDepositario @relation(fields: [reporteId], references: [id], onDelete: Cascade)

  urgencia    FriscoReporteUrgencia
  etiquetas   String[]                                 // ej: ["ocupacion_indebida", "deterioro_grave"]
  resumen     String   @db.Text
  confianza   Float                                    // 0..1
  modelo      String                                   // ej: "llama-3.3-70b-versatile"
  proveedor   String                                   // groq | shipu | fallback
  promptVersion String                                 // ej: "frisco-reporte-v1"
  raw         Json?                                    // payload bruto del modelo (auditoría)
  tokensPrompt    Int?
  tokensRespuesta Int?
  errorMsg    String?  @db.Text                        // si fallback determinístico se activó
  revisadoPor String?                                  // userId que valida/override
  revisadoEn  DateTime?

  createdAt DateTime @default(now())

  @@index([urgencia, createdAt])
  @@map("frisco_reporte_analisis_ia")
}

enum FriscoReporteUrgencia {
  NORMAL
  ATENCION
  CRITICA
}

// ─── Contrato sobre el bien (arrendamiento, administración, comodato) ─────────

model FriscoContrato {
  id     String              @id @default(cuid())
  numero String              @unique
  tipo   FriscoTipoContrato

  bienId String
  bien   FriscoBien @relation(fields: [bienId], references: [id], onDelete: Cascade)

  contraparteNombre    String
  contraparteDocumento String
  contraparteEmail     String?
  contraparteTelefono  String?

  fechaInicio  DateTime
  fechaFin     DateTime?
  canon        Decimal? @db.Decimal(18, 2)
  periodicidad FriscoPeriodicidad?

  polizaNumero       String?
  polizaVigenteHasta DateTime?

  estado        FriscoEstadoContrato @default(VIGENTE)
  observaciones String?              @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bienId])
  @@index([estado])
  @@index([fechaFin])
  @@map("frisco_contratos")
}

enum FriscoTipoContrato {
  ARRENDAMIENTO
  ADMINISTRACION
  COMODATO
  OTRO
}

enum FriscoPeriodicidad {
  MENSUAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

enum FriscoEstadoContrato {
  VIGENTE
  VENCIDO
  TERMINADO
  SUSPENDIDO
}

// ─── Destinación final del bien (1:1 al cerrar ciclo) ─────────────────────────

model FriscoDestinacion {
  id     String                @id @default(cuid())
  bienId String                @unique
  bien   FriscoBien @relation(fields: [bienId], references: [id], onDelete: Cascade)

  tipo               FriscoTipoDestinacion
  fecha              DateTime
  beneficiario       String?                      // víctima, entidad, comprador
  valorRealizacion   Decimal? @db.Decimal(18, 2)
  actoAdministrativo String?                      // resolución / decreto
  observaciones      String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("frisco_destinaciones")
}

enum FriscoTipoDestinacion {
  VICTIMAS
  TRANSFERENCIA
  SUBASTA
  DONACION
  DESTRUCCION
  DEVOLUCION
}

// ─── Interoperabilidad externa (SNR / Fiscalía / IGAC) ────────────────────────

model FriscoInteropLog {
  id        String                 @id @default(cuid())
  servicio  FriscoInteropServicio
  bienId    String?
  bien      FriscoBien? @relation(fields: [bienId], references: [id], onDelete: SetNull)

  consulta  Json                                       // parámetros de entrada
  respuesta Json?                                      // payload remoto si éxito
  exito     Boolean
  errorMsg  String?  @db.Text
  latenciaMs Int?
  usuarioId String?

  createdAt DateTime @default(now())

  @@index([servicio, createdAt])
  @@index([bienId])
  @@map("frisco_interop_logs")
}

enum FriscoInteropServicio {
  SNR
  FISCALIA
  IGAC
}

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║ Módulo Contabilidad Pública (CGN / NICSP)                                  ║
// ║ Motor de doble partida + Plan Único de Cuentas público.                    ║
// ║ Habilita después: presupuesto, tesorería, nómina, contratación.            ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// ─── Plan Único de Cuentas (jerárquico, según CGN) ───────────────────────────

model CpPlanCuenta {
  id          String   @id @default(cuid())
  codigo      String   @unique                        // ej. "1110", "511005"
  nombre      String
  nivel       Int                                     // 1=clase 2=grupo 3=cuenta 4=subcuenta 5=auxiliar
  naturaleza  CpNaturaleza                            // DEBITO o CREDITO
  tipo        CpTipoCuenta                            // BALANCE | RESULTADO | ORDEN
  parentId    String?
  parent      CpPlanCuenta?  @relation("CpJerarquia", fields: [parentId], references: [id])
  hijos       CpPlanCuenta[] @relation("CpJerarquia")
  activa      Boolean  @default(true)
  permiteMovimientos Boolean @default(false)          // sólo cuentas de detalle reciben asientos

  asientos    CpAsiento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([nivel])
  @@map("cp_plan_cuentas")
}

enum CpNaturaleza {
  DEBITO
  CREDITO
}

enum CpTipoCuenta {
  BALANCE      // activos / pasivos / patrimonio
  RESULTADO    // ingresos / gastos
  ORDEN        // cuentas de orden / control
}

// ─── Periodo contable (mensual o anual) ─────────────────────────────────────

model CpPeriodoContable {
  id        String   @id @default(cuid())
  codigo    String   @unique                          // "2026-05" o "2026"
  anio      Int
  mes       Int?                                      // 1..12, null si es periodo anual
  estado    CpEstadoPeriodo @default(ABIERTO)
  fechaInicio DateTime
  fechaFin    DateTime
  cerradoEn DateTime?
  cerradoPor String?

  comprobantes CpComprobante[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([anio, mes])
  @@map("cp_periodos")
}

enum CpEstadoPeriodo {
  ABIERTO
  CERRADO
  AJUSTE       // sólo SUPER_ADMIN puede registrar comprobantes
}

// ─── Tercero auxiliar (NIT/CC, proveedor, contratista, beneficiario, etc.) ───

model CpAuxiliarTercero {
  id          String   @id @default(cuid())
  documento   String   @unique                        // NIT o CC
  tipoDocumento CpTipoDocumento
  razonSocial String
  email       String?
  telefono    String?
  direccion   String?
  ciudad      String?
  activo      Boolean  @default(true)

  asientos    CpAsiento[]
  rps         PsuRp[]    @relation("PsuRpTercero")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([razonSocial])
  @@map("cp_terceros")
}

enum CpTipoDocumento {
  NIT
  CC
  CE
  PA
  OTRO
}

// ─── Comprobante contable (encabezado del asiento) ───────────────────────────

model CpComprobante {
  id          String   @id @default(cuid())
  numero      String   @unique                        // consecutivo "CC-2026-000123"
  tipo        CpTipoComprobante
  fecha       DateTime
  descripcion String   @db.Text
  estado      CpEstadoComprobante @default(REGISTRADO)
  periodoId   String
  periodo     CpPeriodoContable @relation(fields: [periodoId], references: [id])
  totalDebito  Decimal @db.Decimal(18, 2)
  totalCredito Decimal @db.Decimal(18, 2)
  asientos    CpAsiento[]

  // Trazabilidad
  fuenteModulo  String?                                // p.ej. "frisco", "presupuesto", "nomina"
  fuenteRef     String?                                // id en el módulo origen
  creadoPor     String?
  anuladoEn     DateTime?
  anuladoPor    String?
  motivoAnulacion String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([periodoId])
  @@index([fecha])
  @@index([fuenteModulo, fuenteRef])
  @@map("cp_comprobantes")
}

enum CpTipoComprobante {
  CONTABLE        // genérico
  EGRESO
  INGRESO
  AJUSTE
  APERTURA
  CIERRE
}

enum CpEstadoComprobante {
  REGISTRADO
  ANULADO
}

// ─── Asiento (línea de débito/crédito) ──────────────────────────────────────

model CpAsiento {
  id            String   @id @default(cuid())
  comprobanteId String
  comprobante   CpComprobante @relation(fields: [comprobanteId], references: [id], onDelete: Cascade)
  cuentaId      String
  cuenta        CpPlanCuenta @relation(fields: [cuentaId], references: [id])
  terceroId     String?
  tercero       CpAuxiliarTercero? @relation(fields: [terceroId], references: [id])
  debito        Decimal  @db.Decimal(18, 2) @default(0)
  credito       Decimal  @db.Decimal(18, 2) @default(0)
  descripcion   String?

  createdAt DateTime @default(now())

  @@index([comprobanteId])
  @@index([cuentaId])
  @@index([terceroId])
  @@map("cp_asientos")
}

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║ MÓDULO: Ejecución presupuestal (presupuesto_ejecucion)                     ║
// ║ Cadena clásica del gasto público: CDP → RP → Obligación → Pago.            ║
// ║ Cada paso afecta saldos del rubro. El Pago genera el comprobante contable. ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// ─── Rubro presupuestal (jerárquico, gastos/ingresos por fuente) ─────────────

model PsuRubro {
  id          String   @id @default(cuid())
  codigo      String   @unique                            // ej. "A.1.1.01.01"
  nombre      String
  tipo        PsuTipoRubro                                // GASTO | INGRESO
  nivel       Int                                         // 1=clase 2=grupo 3=cuenta 4=auxiliar
  fuente      String?                                     // SGP, propios, regalías, etc.
  programa    String?
  proyecto    String?
  parentId    String?
  parent      PsuRubro?  @relation("PsuJerarquia", fields: [parentId], references: [id])
  hijos       PsuRubro[] @relation("PsuJerarquia")
  permiteMovimientos Boolean @default(false)              // sólo hojas
  activa      Boolean  @default(true)

  apropiaciones PsuApropiacion[]
  cdps          PsuCdp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([nivel])
  @@map("psu_rubros")
}

enum PsuTipoRubro {
  GASTO
  INGRESO
}

// ─── Apropiación: techo presupuestal por rubro y vigencia ────────────────────

model PsuApropiacion {
  id          String   @id @default(cuid())
  rubroId     String
  rubro       PsuRubro @relation(fields: [rubroId], references: [id])
  vigencia    Int                                         // año
  apropiacionInicial Decimal @db.Decimal(18, 2) @default(0)
  adiciones          Decimal @db.Decimal(18, 2) @default(0)
  reducciones        Decimal @db.Decimal(18, 2) @default(0)
  // saldo disponible = apropiacionInicial + adiciones - reducciones - comprometido
  // (el comprometido se calcula desde los CDP activos del mismo rubro+vigencia)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rubroId, vigencia])
  @@index([vigencia])
  @@map("psu_apropiaciones")
}

// ─── CDP: Certificado de Disponibilidad Presupuestal ─────────────────────────

model PsuCdp {
  id          String   @id @default(cuid())
  numero      String   @unique                            // "CDP-2026-000123"
  fecha       DateTime
  vigencia    Int
  rubroId     String
  rubro       PsuRubro @relation(fields: [rubroId], references: [id])
  valor       Decimal  @db.Decimal(18, 2)
  objeto      String   @db.Text                           // descripción del gasto
  estado      PsuEstadoDoc @default(VIGENTE)
  creadoPor   String?
  anuladoEn   DateTime?
  anuladoPor  String?
  motivoAnulacion String? @db.Text

  rps         PsuRp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vigencia])
  @@index([rubroId])
  @@map("psu_cdps")
}

enum PsuEstadoDoc {
  VIGENTE
  ANULADO
  AGOTADO        // todo el valor está comprometido en pasos siguientes
}

// ─── RP: Registro Presupuestal (compromiso) — afecta a un CDP ────────────────

model PsuRp {
  id          String   @id @default(cuid())
  numero      String   @unique                            // "RP-2026-000123"
  fecha       DateTime
  cdpId       String
  cdp         PsuCdp   @relation(fields: [cdpId], references: [id])
  terceroId   String?                                     // contratista / beneficiario
  tercero     CpAuxiliarTercero? @relation("PsuRpTercero", fields: [terceroId], references: [id])
  valor       Decimal  @db.Decimal(18, 2)
  objeto      String   @db.Text
  estado      PsuEstadoDoc @default(VIGENTE)
  creadoPor   String?
  anuladoEn   DateTime?
  anuladoPor  String?
  motivoAnulacion String? @db.Text

  obligaciones PsuObligacion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cdpId])
  @@index([terceroId])
  @@map("psu_rps")
}

// ─── Obligación: cuenta por pagar reconocida — afecta a un RP ────────────────

model PsuObligacion {
  id          String   @id @default(cuid())
  numero      String   @unique                            // "OBL-2026-000123"
  fecha       DateTime
  rpId        String
  rp          PsuRp    @relation(fields: [rpId], references: [id])
  valor       Decimal  @db.Decimal(18, 2)
  concepto    String   @db.Text
  estado      PsuEstadoDoc @default(VIGENTE)
  creadoPor   String?
  anuladoEn   DateTime?
  anuladoPor  String?
  motivoAnulacion String? @db.Text

  pagos       PsuPago[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rpId])
  @@map("psu_obligaciones")
}

// ─── Pago: ejecución del pago — genera comprobante contable ──────────────────

model PsuPago {
  id          String   @id @default(cuid())
  numero      String   @unique                            // "PG-2026-000123"
  fecha       DateTime
  obligacionId String
  obligacion  PsuObligacion @relation(fields: [obligacionId], references: [id])
  valor       Decimal  @db.Decimal(18, 2)
  medioPago   PsuMedioPago
  referencia  String?                                     // egreso, transferencia, cheque
  estado      PsuEstadoDoc @default(VIGENTE)

  // Vínculo a contabilidad (CpComprobante generado automáticamente)
  comprobanteId String?
  cuentaBancoId String?                                   // cuenta CP del débito de banco/caja

  creadoPor   String?
  anuladoEn   DateTime?
  anuladoPor  String?
  motivoAnulacion String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([obligacionId])
  @@map("psu_pagos")
}

enum PsuMedioPago {
  TRANSFERENCIA
  CHEQUE
  EFECTIVO
  OTRO
}

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║ MÓDULO: Nómina pública (nomina_publica)                                    ║
// ║ Maneja empleados (planta y contratistas), conceptos de devengado y         ║
// ║ deducción (PUC CGC + rubros CCPET A.1), liquidación mensual, integración   ║
// ║ con presupuesto (Obligación/Pago) y contabilidad (CpComprobante).          ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// ─── Empleado / vinculado ────────────────────────────────────────────────────

model NomEmpleado {
  id              String   @id @default(cuid())
  documento       String   @unique
  tipoDocumento   String                                       // CC|CE|PA|NIT
  primerNombre    String
  segundoNombre   String?
  primerApellido  String
  segundoApellido String?
  email           String?
  telefono        String?
  cargo           String
  dependencia     String?
  tipoVinculacion NomTipoVinculacion @default(PLANTA)
  fechaIngreso    DateTime
  fechaRetiro     DateTime?
  activo          Boolean  @default(true)
  salarioBasico   Decimal  @db.Decimal(18, 2)
  // Identificadores bancarios / aportes
  cuentaBanco     String?
  bancoNombre     String?
  tipoCuenta      String?                                      // AHORROS|CORRIENTE
  eps             String?
  afp             String?
  arl             String?
  cajaCompensacion String?
  // Información tributaria
  retencionFuenteAplica Boolean @default(true)

  liquidaciones NomLiquidacion[]
  novedades     NomNovedad[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activo])
  @@index([dependencia])
  @@map("nom_empleados")
}

enum NomTipoVinculacion {
  PLANTA            // empleado público de carrera o libre nombramiento
  TRABAJADOR_OFICIAL
  CONTRATISTA       // OPS — prestación de servicios
  SUPERNUMERARIO
  APRENDIZ
}

// ─── Concepto de nómina (devengado o deducción) ──────────────────────────────

model NomConcepto {
  id          String   @id @default(cuid())
  codigo      String   @unique                                // NC-001, NC-002
  nombre      String
  tipo        NomTipoConcepto
  // Base de cálculo
  formula     NomFormulaConcepto @default(FIJO)
  porcentaje  Decimal? @db.Decimal(6, 4)                      // ej 0.04 = 4%
  valorFijo   Decimal? @db.Decimal(18, 2)
  // Aplica a
  aplicaA     NomTipoVinculacion[]                            // a quiénes aplica
  // Comportamiento contable / tributario
  baseRetencion Boolean @default(false)                       // suma a base retención
  baseAportes   Boolean @default(false)                       // suma a IBC
  constitutivoSalario Boolean @default(true)
  // Cuenta CGC asociada (gasto si devengado, pasivo si deducción)
  cuentaContableCodigo String?                                // ej "510101", "243603"
  // Rubro CCPET asociado (sólo devengados)
  rubroCcpetCodigo     String?                                // ej "2.1.1.01.01.01.01"
  // Orden de aplicación dentro de la liquidación
  orden       Int      @default(100)
  activo      Boolean  @default(true)

  detalles    NomLiquidacionDetalle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nom_conceptos")
}

enum NomTipoConcepto {
  DEVENGADO            // sueldo, prima, bonificación, auxilio
  DEDUCCION_EMPLEADO   // pensión 4%, salud 4%, retefuente, embargos
  APORTE_PATRONAL      // pensión 12%, salud 8.5%, ARL, parafiscales
  PRESTACION_SOCIAL    // cesantías, intereses, primas (provisiones)
}

enum NomFormulaConcepto {
  FIJO                 // valorFijo en el empleado (manual)
  PORCENTAJE_SUELDO    // porcentaje * salarioBasico
  PORCENTAJE_DEVENGADO // porcentaje * suma devengados constitutivos
  PORCENTAJE_IBC       // porcentaje * Ingreso Base de Cotización
  CALCULO_ESPECIAL     // ej cesantías: prom 12 meses, vacaciones: días*salario/30
}

// ─── Periodo de nómina ───────────────────────────────────────────────────────

model NomNominaPeriodo {
  id          String   @id @default(cuid())
  codigo      String   @unique                                // "2026-05"
  anio        Int
  mes         Int                                             // 1..12
  estado      NomEstadoPeriodo @default(ABIERTO)
  fechaInicio DateTime
  fechaFin    DateTime
  liquidadoEn DateTime?
  liquidadoPor String?

  liquidaciones NomLiquidacion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([anio, mes])
  @@map("nom_periodos")
}

enum NomEstadoPeriodo {
  ABIERTO          // se puede liquidar
  LIQUIDADO        // ya liquidado, sólo lectura
  PAGADO           // pagado a empleados (genera comprobantes)
  CERRADO          // cerrado contablemente
}

// ─── Liquidación (1 por empleado por periodo) ────────────────────────────────

model NomLiquidacion {
  id          String   @id @default(cuid())
  periodoId   String
  periodo     NomNominaPeriodo @relation(fields: [periodoId], references: [id])
  empleadoId  String
  empleado    NomEmpleado @relation(fields: [empleadoId], references: [id])
  // Acumulados
  totalDevengado Decimal @db.Decimal(18, 2) @default(0)
  totalDeducciones Decimal @db.Decimal(18, 2) @default(0)
  totalAportesPatronales Decimal @db.Decimal(18, 2) @default(0)
  netoPagar      Decimal @db.Decimal(18, 2) @default(0)
  // Días liquidados
  diasLiquidados Int @default(30)
  // Salario base usado
  salarioBasico  Decimal @db.Decimal(18, 2)
  // Vínculos a presupuesto / contabilidad
  obligacionId   String?
  comprobanteId  String?

  detalles NomLiquidacionDetalle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodoId, empleadoId])
  @@index([empleadoId])
  @@map("nom_liquidaciones")
}

// ─── Detalle de liquidación (línea por concepto aplicado) ────────────────────

model NomLiquidacionDetalle {
  id            String   @id @default(cuid())
  liquidacionId String
  liquidacion   NomLiquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  conceptoId    String
  concepto      NomConcepto @relation(fields: [conceptoId], references: [id])
  valor         Decimal  @db.Decimal(18, 2)
  base          Decimal? @db.Decimal(18, 2)                   // base usada para el cálculo
  observacion   String?

  createdAt DateTime @default(now())

  @@index([liquidacionId])
  @@index([conceptoId])
  @@map("nom_liquidacion_detalles")
}

// ─── Novedad (vacaciones, licencia, ausencia, incapacidad) ───────────────────

model NomNovedad {
  id          String   @id @default(cuid())
  empleadoId  String
  empleado    NomEmpleado @relation(fields: [empleadoId], references: [id])
  tipo        NomTipoNovedad
  fechaInicio DateTime
  fechaFin    DateTime
  dias        Int
  observacion String?
  valor       Decimal? @db.Decimal(18, 2)                     // si aplica (ej. liquidación de vacaciones)
  aprobada    Boolean @default(false)
  aprobadaPor String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empleadoId])
  @@index([fechaInicio])
  @@map("nom_novedades")
}

enum NomTipoNovedad {
  VACACIONES
  LICENCIA_REMUNERADA
  LICENCIA_NO_REMUNERADA
  INCAPACIDAD_EPS          // pagada por EPS
  INCAPACIDAD_ARL          // pagada por ARL
  AUSENCIA                 // descontable
  COMISION_SERVICIOS
  PERMISO
}

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║ MÓDULO: Reportes a entes de control (reportes_control)                     ║
// ║ Genera snapshots periódicos para CHIP (CGN), FUT (DNP), Ley 617,           ║
// ║ persistidos como JSON descargable para mapear a las plantillas oficiales.  ║
// ╚════════════════════════════════════════════════════════════════════════════╝

model RcReporteGenerado {
  id           String   @id @default(cuid())
  tipo         RcTipoReporte
  // Identificación del corte (uno de los dos según el tipo):
  periodoContableId String?                                  // CHIP_BALANCE / CHIP_ACTIVIDAD
  vigencia          Int?                                     // FUT_INGRESOS / FUT_GASTOS / LEY_617
  // Resultado
  datos        Json
  totales      Json?                                         // resumen para listar
  // Metadata
  generadoPor  String?
  generadoEn   DateTime @default(now())
  observacion  String?

  @@index([tipo, vigencia])
  @@index([tipo, periodoContableId])
  @@map("rc_reportes")
}

enum RcTipoReporte {
  CHIP_BALANCE       // Balance General CGN: saldos clase 1, 2, 3 al cierre del periodo
  CHIP_ACTIVIDAD     // Estado de Actividad CGN: ingresos (clase 4) y gastos (clase 5)
  FUT_INGRESOS       // Ejecución de ingresos por rubro CCPET
  FUT_GASTOS         // Ejecución de gastos: apropiación / comprometido / obligado / pagado
  LEY_617            // Indicador gastos de funcionamiento sobre ICLD (40% para personerías)
}
