// ==========================================
// FASE 3: PLATAFORMA NACIONAL
// ==========================================

// ─── 3.1 Plan Config (cuotas locales por tenant) ─────────────────────────────
model GdPlanConfig {
  id                 String      @id @default(cuid())
  nivel              GdPlanNivel @default(BASICO)
  limiteRadicados    Int         @default(50000)   // Radicados/año
  limiteSedes        Int         @default(1)
  apiPublica         Boolean     @default(false)
  slaHoras           Int         @default(72)       // SLA respuesta en horas
  radicadosActuales  Int         @default(0)        // Conteo acumulado año actual
  anioActual         Int         @default(2026)
  activo             Boolean     @default(true)
  fechaVencimiento   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gd_plan_config")
}

enum GdPlanNivel {
  BASICO        // 50k rad/año, 1 sede, sin API pública
  PROFESIONAL   // 200k rad/año, 3 sedes, API lectura
  ENTERPRISE    // ilimitado, N sedes, API completa, SLA
}

// ─── 3.3 API Keys (autenticación API pública REST) ────────────────────────────
model GdApiKey {
  id          String    @id @default(cuid())
  nombre      String                        // "App Ventanilla Medellín"
  keyHash     String    @unique             // bcrypt hash del API key
  keyPrefix   String                        // primeros 8 chars para identificar
  permisos    Json      @default("[]")      // ["radicados:read","radicados:write"]
  activo      Boolean   @default(true)
  ultimoUso   DateTime?
  usosTotal   Int       @default(0)

  creadorId   String
  creador     Usuario   @relation("GdApiKeyCreador", fields: [creadorId], references: [id])

  logs        GdApiLog[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([keyHash])
  @@index([activo])
  @@map("gd_api_keys")
}

// ─── 3.3 API Logs (registro de uso API pública) ──────────────────────────────
model GdApiLog {
  id        String   @id @default(cuid())
  metodo    String   // GET, POST
  ruta      String   // /api/v1/public/radicados
  status    Int      // 200, 401, 429
  ip        String?
  duracionMs Int     @default(0)

  apiKeyId  String
  apiKey    GdApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([apiKeyId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("gd_api_logs")
}

// ─── 3.4 SIGEP Cache (caché local directorio funcionarios) ────────────────────
model GdSigepCache {
  id           String   @id @default(cuid())
  cedula       String   @unique
  nombre       String
  cargo        String?
  entidad      String?
  dependencia  String?
  email        String?
  telefono     String?
  datosJson    Json?    // Respuesta completa de SIGEP
  expiraEn     DateTime // TTL: cuándo revalidar

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([expiraEn])
  @@index([nombre])
  @@map("gd_sigep_cache")
}
