  resolucion String? @db.Text

  atendidoPorId String?
  atendidoPor   Usuario? @relation("VuAtencionAtendidoPor", fields: [atendidoPorId], references: [id])

  duracionMinutos Int?
  satisfaccion    Int?  // 1-5

  createdAt DateTime @default(now())

  @@index([canal, createdAt])
  @@map("vu_registro_atencion")
}

/// Plantilla reutilizable para generar reportes
model VuPlantillaReporte {
  id          String  @id @default(cuid())
  nombre      String  @unique
  descripcion String? @db.Text
  consulta    Json    // estructura del reporte (filtros, agrupaciones, columnas)
  esPublica   Boolean @default(true)

  creadoPorId String?
  creadoPor   Usuario? @relation("VuReportePlantillaCreador", fields: [creadoPorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reportes VuReporte[]

  @@map("vu_plantillas_reporte")
}

/// Reporte generado (instancia ejecutada de una plantilla)
model VuReporte {
  id          String  @id @default(cuid())
  plantillaId String?
  plantilla   VuPlantillaReporte? @relation(fields: [plantillaId], references: [id])

  parametros Json    // valores con que se ejecuto
  resultado  Json    // snapshot del resultado en el momento de generarlo
  archivoUrl String? // exportacion (PDF/XLSX/CSV)

  generadoPorId String?
  generadoPor   Usuario? @relation("VuReporteGenerador", fields: [generadoPorId], references: [id])

  periodoDesde DateTime?
  periodoHasta DateTime?

  createdAt DateTime @default(now())

  @@index([plantillaId, createdAt(sort: Desc)])
  @@map("vu_reportes")
}

/// Opciones configurables para listas desplegables en el modulo VU
model VuOpcionDropdown {
  id       String  @id @default(cuid())
  grupo    String  // ej: "ZONA", "MOTIVO_CIERRE", "TIPO_DOCUMENTO"
  valor    String
  etiqueta String
  orden    Int     @default(0)
  activa   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([grupo, valor])
  @@index([grupo, orden])
  @@map("vu_opciones_dropdown")
}

/// Documento asociado a un PQRS dentro del modulo VU.
/// Diferenciado de `Documento` (transversal del portal) y `GdDocumento`
/// (gestion documental Orfeo). Ideal para adjuntos del ciudadano y
/// evidencias del funcionario sobre un caso especifico.
model VuDocumento {
  id            String  @id @default(cuid())
  pqrsId        String
  pqrs          PQRS    @relation("VuDocumentoPqrs", fields: [pqrsId], references: [id], onDelete: Cascade)

  fileName      String  // nombre saneado
  originalName  String  // nombre original subido por el usuario
  mimeType      String
  fileSize      Int
  fileUrl       String  @db.Text
  fileKey       String? @db.Text  // key relativo en el storage para delete
  fileHash      String?

  documentType  VuTipoDocumento @default(OTRO)
  descripcion   String?         @db.Text
  esInterno     Boolean         @default(false)

  subidoPorId    String?
  subidoPor      Usuario? @relation("VuDocumentoSubidoPor", fields: [subidoPorId], references: [id])
  subidoPorTipo  String  @default("USER") // USER | CITIZEN | SYSTEM

  createdAt DateTime @default(now())

  @@index([pqrsId, createdAt(sort: Desc)])
  @@map("vu_documentos")
}

enum VuTipoDocumento {
  SOLICITUD       // documento original del ciudadano
  EVIDENCIA       // soporte aportado
  RESPUESTA       // respuesta oficial generada
  ANEXO           // anexo complementario
  NOTA_INTERNA    // documento interno (no visible al ciudadano)
  OTRO
}

/// Token externo para que el ciudadano consulte / responda sin autenticarse
model VuRutaTokenExterno {
  id     String @id @default(cuid())
  token  String @unique  // se entrega al ciudadano
  pqrsId String
  pqrs   PQRS   @relation(fields: [pqrsId], references: [id], onDelete: Cascade)

  // Permisos del token
  permiteConsulta  Boolean @default(true)
  permiteResponder Boolean @default(false)

  expiraEn   DateTime?
  ultimoUsoEn DateTime?
  vecesUsado  Int      @default(0)
  revocadoEn  DateTime?

  createdAt DateTime @default(now())

  @@index([pqrsId])
  @@map("vu_rutas_token_externo")
}

// ============================================================================
// FRISCO ГўвӮ¬вҖқ Bienes en proceso de extinciГғВіn de dominio (mГғВіdulo vertical SAE)
// ----------------------------------------------------------------------------
// Activado por el mГғВіdulo `frisco_bienes`. Cada bien queda vinculado a un
// expediente documental (GdExpediente) y, opcionalmente, a su ubicaciГғВіn
// fГғВӯsica en archivo (GaCarpeta) cuando aplica. Tablas pensadas para soportar
// el ciclo: ingreso por orden judicial ГўвҖ вҖҷ custodia ГўвҖ вҖҷ contratos ГўвҖ вҖҷ destinaciГғВіn.
// ============================================================================

model FriscoBien {
  id              String   @id @default(cuid())
  codigo          String   @unique                 // consecutivo interno
  folioMatricula  String?                          // SNR ГўвӮ¬вҖқ inmuebles
  placa           String?                          // automotores
  tipo            FriscoTipoBien
  estadoJuridico  FriscoEstadoJuridico @default(EN_PROCESO)
  estadoFisico    FriscoEstadoFisico?  @default(SIN_VERIFICAR)

  descripcion     String   @db.Text
  ubicacion       String?                          // direcciГғВіn textual
  latitud         Float?
  longitud        Float?

  avaluoVigente   Decimal? @db.Decimal(18, 2)
  monedaAvaluo    String?  @default("COP")
  fechaAvaluo     DateTime?

  numeroProceso   String?                          // proceso de extinciГғВіn
  fechaIngreso    DateTime @default(now())
  juzgado         String?

  // VГғВӯnculos a documentaciГғВіn
  expedienteId    String?
  expediente      GdExpediente? @relation(fields: [expedienteId], references: [id])
  carpetaFisicaId String?
  carpetaFisica   GaCarpeta?    @relation(fields: [carpetaFisicaId], references: [id])

  depositarios FriscoDepositario[]
  contratos    FriscoContrato[]
  destinacion  FriscoDestinacion?
  interopLogs  FriscoInteropLog[]

  observaciones String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estadoJuridico])
  @@index([tipo])
  @@index([folioMatricula])
  @@index([placa])
  @@index([numeroProceso])
  @@map("frisco_bienes")
}

enum FriscoTipoBien {
  INMUEBLE_URBANO
  INMUEBLE_RURAL
  VEHICULO
  SEMOVIENTE
  ESTABLECIMIENTO_COMERCIO
  EMBARCACION
  AERONAVE
  OBRA_ARTE
  TITULO_VALOR
  EMPRESA
  OTRO
}

enum FriscoEstadoJuridico {
  EN_PROCESO   // proceso activo de extinciГғВіn
  CAUTELAR     // medida cautelar vigente
  EXTINTO      // sentencia de extinciГғВіn ejecutoriada
  DEVUELTO     // devuelto al propietario original
}

enum FriscoEstadoFisico {
  BUENO
  REGULAR
  MALO
  PERDIDO
  DESTRUIDO
  SIN_VERIFICAR
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Depositario: custodio temporal de un bien ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model FriscoDepositario {
  id          String   @id @default(cuid())
  tipoPersona FriscoTipoPersona
  nombre      String
  documento   String                              // cГғВ©dula o NIT
  email       String?
  telefono    String?
  direccion   String?

  bienId String
  bien   FriscoBien @relation(fields: [bienId], references: [id], onDelete: Cascade)

  fechaAsignacion    DateTime
  fechaFin           DateTime?
  activo             Boolean   @default(true)
  ultimoReporte      DateTime?
  polizaVigenteHasta DateTime?

  observaciones String? @db.Text

  accesos  FriscoPortalAcceso[]
  reportes FriscoReporteDepositario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bienId])
  @@index([activo])
  @@index([documento])
  @@map("frisco_depositarios")
}

enum FriscoTipoPersona {
  NATURAL
  JURIDICA
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Portal externo del depositario: acceso por token + reportes mensuales ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model FriscoPortalAcceso {
  id            String   @id @default(cuid())
  tokenHash     String   @unique                    // SHA-256 del token; el token plano nunca se persiste
  depositarioId String
  depositario   FriscoDepositario @relation(fields: [depositarioId], references: [id], onDelete: Cascade)

  expiraEn      DateTime
  revocadoEn    DateTime?
  ultimoAccesoEn DateTime?
  accesoCount   Int      @default(0)

  createdAt DateTime @default(now())
  createdBy String?

  @@index([depositarioId])
  @@index([expiraEn])
  @@map("frisco_portal_accesos")
}

model FriscoReporteDepositario {
  id            String   @id @default(cuid())
  depositarioId String
  depositario   FriscoDepositario @relation(fields: [depositarioId], references: [id], onDelete: Cascade)

  periodo       String                              // "YYYY-MM"
  estadoBien    FriscoEstadoFisico
  novedades     String   @db.Text
  fotoUrl       String?                             // URL de foto subida (opcional)
  adjuntoUrl    String?                             // URL de documento adjunto (opcional)
  ipOrigen      String?

  analisisIA    FriscoReporteAnalisisIA?

  createdAt DateTime @default(now())

  @@unique([depositarioId, periodo])
  @@index([periodo])
  @@map("frisco_reportes_depositario")
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ AnГғВЎlisis IA del reporte (sugiere, humano decide) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model FriscoReporteAnalisisIA {
  id          String   @id @default(cuid())
  reporteId   String   @unique
  reporte     FriscoReporteDepositario @relation(fields: [reporteId], references: [id], onDelete: Cascade)

  urgencia    FriscoReporteUrgencia
  etiquetas   String[]                                 // ej: ["ocupacion_indebida", "deterioro_grave"]
  resumen     String   @db.Text
  confianza   Float                                    // 0..1
  modelo      String                                   // ej: "llama-3.3-70b-versatile"
  proveedor   String                                   // groq | shipu | fallback
  promptVersion String                                 // ej: "frisco-reporte-v1"
  raw         Json?                                    // payload bruto del modelo (auditorГғВӯa)
  tokensPrompt    Int?
  tokensRespuesta Int?
  errorMsg    String?  @db.Text                        // si fallback determinГғВӯstico se activГғВі
  revisadoPor String?                                  // userId que valida/override
  revisadoEn  DateTime?

  createdAt DateTime @default(now())

  @@index([urgencia, createdAt])
  @@map("frisco_reporte_analisis_ia")
}

enum FriscoReporteUrgencia {
  NORMAL
  ATENCION
  CRITICA
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Contrato sobre el bien (arrendamiento, administraciГғВіn, comodato) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model FriscoContrato {
  id     String              @id @default(cuid())
  numero String              @unique
  tipo   FriscoTipoContrato

  bienId String
  bien   FriscoBien @relation(fields: [bienId], references: [id], onDelete: Cascade)

  contraparteNombre    String
  contraparteDocumento String
  contraparteEmail     String?
  contraparteTelefono  String?

  fechaInicio  DateTime
  fechaFin     DateTime?
  canon        Decimal? @db.Decimal(18, 2)
  periodicidad FriscoPeriodicidad?

  polizaNumero       String?
  polizaVigenteHasta DateTime?

  estado        FriscoEstadoContrato @default(VIGENTE)
  observaciones String?              @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bienId])
  @@index([estado])
  @@index([fechaFin])
  @@map("frisco_contratos")
}

enum FriscoTipoContrato {
  ARRENDAMIENTO
  ADMINISTRACION
  COMODATO
  OTRO
}

enum FriscoPeriodicidad {
  MENSUAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

enum FriscoEstadoContrato {
  VIGENTE
  VENCIDO
  TERMINADO
  SUSPENDIDO
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ DestinaciГғВіn final del bien (1:1 al cerrar ciclo) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model FriscoDestinacion {
  id     String                @id @default(cuid())
  bienId String                @unique
  bien   FriscoBien @relation(fields: [bienId], references: [id], onDelete: Cascade)

  tipo               FriscoTipoDestinacion
  fecha              DateTime
  beneficiario       String?                      // vГғВӯctima, entidad, comprador
  valorRealizacion   Decimal? @db.Decimal(18, 2)
  actoAdministrativo String?                      // resoluciГғВіn / decreto
  observaciones      String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("frisco_destinaciones")
}

enum FriscoTipoDestinacion {
  VICTIMAS
  TRANSFERENCIA
  SUBASTA
  DONACION
  DESTRUCCION
  DEVOLUCION
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Interoperabilidad externa (SNR / FiscalГғВӯa / IGAC) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model FriscoInteropLog {
  id        String                 @id @default(cuid())
  servicio  FriscoInteropServicio
  bienId    String?
  bien      FriscoBien? @relation(fields: [bienId], references: [id], onDelete: SetNull)

  consulta  Json                                       // parГғВЎmetros de entrada
  respuesta Json?                                      // payload remoto si ГғВ©xito
  exito     Boolean
  errorMsg  String?  @db.Text
  latenciaMs Int?
  usuarioId String?

  createdAt DateTime @default(now())

  @@index([servicio, createdAt])
  @@index([bienId])
  @@map("frisco_interop_logs")
}

enum FriscoInteropServicio {
  SNR
  FISCALIA
  IGAC
}

// ГўвҖўвҖқГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўвҖ”
// ГўвҖўвҖҳ MГғВіdulo Contabilidad PГғВәblica (CGN / NICSP)                                  ГўвҖўвҖҳ
