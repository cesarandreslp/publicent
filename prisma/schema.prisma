// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Plan ГғЕЎnico de Cuentas (jerГғВЎrquico, segГғВәn CGN) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model CpPlanCuenta {
  id          String   @id @default(cuid())
  codigo      String   @unique                        // ej. "1110", "511005"
  nombre      String
  nivel       Int                                     // 1=clase 2=grupo 3=cuenta 4=subcuenta 5=auxiliar
  naturaleza  CpNaturaleza                            // DEBITO o CREDITO
  tipo        CpTipoCuenta                            // BALANCE | RESULTADO | ORDEN
  parentId    String?
  parent      CpPlanCuenta?  @relation("CpJerarquia", fields: [parentId], references: [id])
  hijos       CpPlanCuenta[] @relation("CpJerarquia")
  activa      Boolean  @default(true)
  permiteMovimientos Boolean @default(false)          // sГғВіlo cuentas de detalle reciben asientos

  asientos    CpAsiento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([nivel])
  @@map("cp_plan_cuentas")
}

enum CpNaturaleza {
  DEBITO
  CREDITO
}

enum CpTipoCuenta {
  BALANCE      // activos / pasivos / patrimonio
  RESULTADO    // ingresos / gastos
  ORDEN        // cuentas de orden / control
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Periodo contable (mensual o anual) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model CpPeriodoContable {
  id        String   @id @default(cuid())
  codigo    String   @unique                          // "2026-05" o "2026"
  anio      Int
  mes       Int?                                      // 1..12, null si es periodo anual
  estado    CpEstadoPeriodo @default(ABIERTO)
  fechaInicio DateTime
  fechaFin    DateTime
  cerradoEn DateTime?
  cerradoPor String?

  comprobantes CpComprobante[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([anio, mes])
  @@map("cp_periodos")
}

enum CpEstadoPeriodo {
  ABIERTO
  CERRADO
  AJUSTE       // sГғВіlo SUPER_ADMIN puede registrar comprobantes
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Tercero auxiliar (NIT/CC, proveedor, contratista, beneficiario, etc.) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model CpAuxiliarTercero {
  id          String   @id @default(cuid())
  documento   String   @unique                        // NIT o CC
  tipoDocumento CpTipoDocumento
  razonSocial String
  email       String?
  telefono    String?
  direccion   String?
  ciudad      String?
  activo      Boolean  @default(true)

  asientos    CpAsiento[]
  rps         PsuRp[]    @relation("PsuRpTercero")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([razonSocial])
  @@map("cp_terceros")
}

enum CpTipoDocumento {
  NIT
  CC
  CE
  PA
  OTRO
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Comprobante contable (encabezado del asiento) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model CpComprobante {
  id          String   @id @default(cuid())
  numero      String   @unique                        // consecutivo "CC-2026-000123"
  tipo        CpTipoComprobante
  fecha       DateTime
  descripcion String   @db.Text
  estado      CpEstadoComprobante @default(REGISTRADO)
  periodoId   String
  periodo     CpPeriodoContable @relation(fields: [periodoId], references: [id])
  totalDebito  Decimal @db.Decimal(18, 2)
  totalCredito Decimal @db.Decimal(18, 2)
  asientos    CpAsiento[]

  // Trazabilidad
  fuenteModulo  String?                                // p.ej. "frisco", "presupuesto", "nomina"
  fuenteRef     String?                                // id en el mГғВіdulo origen
  creadoPor     String?
  anuladoEn     DateTime?
  anuladoPor    String?
  motivoAnulacion String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([periodoId])
  @@index([fecha])
  @@index([fuenteModulo, fuenteRef])
  @@map("cp_comprobantes")
}

enum CpTipoComprobante {
  CONTABLE        // genГғВ©rico
  EGRESO
  INGRESO
  AJUSTE
  APERTURA
  CIERRE
}

enum CpEstadoComprobante {
  REGISTRADO
  ANULADO
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Asiento (lГғВӯnea de dГғВ©bito/crГғВ©dito) ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

model CpAsiento {
  id            String   @id @default(cuid())
  comprobanteId String
  comprobante   CpComprobante @relation(fields: [comprobanteId], references: [id], onDelete: Cascade)
  cuentaId      String
  cuenta        CpPlanCuenta @relation(fields: [cuentaId], references: [id])
  terceroId     String?
  tercero       CpAuxiliarTercero? @relation(fields: [terceroId], references: [id])
  debito        Decimal  @db.Decimal(18, 2) @default(0)
  credito       Decimal  @db.Decimal(18, 2) @default(0)
  descripcion   String?

  createdAt DateTime @default(now())

  @@index([comprobanteId])
  @@index([cuentaId])
  @@index([terceroId])
  @@map("cp_asientos")
}

// ГўвҖўвҖқГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўвҖ”
